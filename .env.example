# ─── Resend (required for contact form + newsletter) ───
# 1. Sign up at https://resend.com
# 2. Create an API key → paste below
# 3. Verify your domain (khushbooparmar.com) in Resend → Domains
# 4. Set NEWSLETTER_FROM_EMAIL to an address on your verified domain (e.g. hello@khushbooparmar.com)
# 5. Until your domain is verified, Resend only delivers to the email you signed up with
RESEND_API_KEY=re_xxxxxxxxxxxx

# Where contact form messages are delivered (use your real inbox)
CONTACT_EMAIL=Khushbooparmar1508@gmail.com

# Sender for contact notifications (verify domain in Resend, or use onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=hello@khushbooparmar.com

# Sender for newsletter emails (must use a verified domain in production)
NEWSLETTER_FROM_EMAIL=hello@khushbooparmar.com

# Site URL
NEXT_PUBLIC_SITE_URL=https://khushbooparmar.com
